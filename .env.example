# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- OpenAI-compatible LLM tiers ---
# These defaults point at OmniRoute. The same variables also work with direct provider
# or local OpenAI-compatible endpoints. Per-tier URL/key overrides are optional.
LLM_API_KEY=
LLM_BASE_URL=http://localhost:20128/v1
LLM_EASY_MODEL=legal-easy
LLM_HARD_MODEL=legal-hard-live
LLM_EASY_MAX_TOKENS=256
LLM_HARD_MAX_TOKENS=1024
# Optional provider-specific OpenAI extra_body JSON. Nemotron uses this to avoid
# spending the answer budget on an internal reasoning trace.
LLM_HARD_EXTRA_BODY={"thinking":{"type":"disabled"},"chat_template_kwargs":{"enable_thinking":false}}
LLM_TIMEOUT_SECONDS=90
# OmniRoute strips this DeepSeek-specific field for Mistral/NVIDIA targets.
LLM_DISABLE_THINKING=true

# Optional direct/local overrides. Blank values inherit LLM_API_KEY / LLM_BASE_URL.
LLM_EASY_API_KEY=
LLM_EASY_BASE_URL=
LLM_HARD_API_KEY=
LLM_HARD_BASE_URL=

# --- RAGAS judge (pinned, no fallback) ---
# Use ragas-judge-dev for NVIDIA experiments. Switch to a separate pinned DeepSeek
# Flash alias for release numbers that must remain comparable with the old runs.
RAGAS_JUDGE_API_KEY=
RAGAS_JUDGE_BASE_URL=
RAGAS_JUDGE_MODEL=ragas-judge-dev
RAGAS_JUDGE_MAX_TOKENS=4096
RAGAS_JUDGE_DISABLE_THINKING=false
RAGAS_JUDGE_MAX_RETRIES=2
RAGAS_JUDGE_TIMEOUT_SECONDS=180
RAGAS_MAX_WORKERS=2
# Answer-relevancy uses this local sentence-transformer, not another API provider.
RAGAS_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Tracing (LangSmith free tier) ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-legal-rag

# --- Vector DB (Qdrant) ---
# Optional managed Qdrant URL. Leave blank to use the embedded local index.
QDRANT_URL=
QDRANT_COLLECTION=legal

# --- Retrieval knobs (defaults; see NOTES.md architecture) ---
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
RRF_K=60
OOD_DISTANCE_THRESHOLD=0.75
RETRIEVAL_LOOP_BUDGET=2

# --- HuggingFace (gated eval datasets: opennyaiorg/aibe_dataset, bharatgenai/BhashaBench-Legal) ---
HF_TOKEN=

# Experimental full graph only. Production skips the grader.
GRADER_TIER=easy
