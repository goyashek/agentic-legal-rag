# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- LLM (Gemini) ---
GEMINI_API_KEY=
# Flash-tier for routing/grading/checking/rewriting/intent, Pro for generation.
# flash-lite over 2.5-flash on the free tier: 500 req/day vs 20 (2.5-flash's daily
# cap is tiny, and the grader fans out ~8 calls per query). Bump to a 2.5/3.x flash
# if you enable billing. NOTE: Gemini Pro has NO free tier (0/day) — generation
# needs billing, or set PRO to a flash-lite tier for a key-only run.
GEMINI_MODEL_FLASH=gemini-3.1-flash-lite
GEMINI_MODEL_PRO=gemini-2.5-pro

# --- Alternate LLM backend (OpenAI-compatible; escapes the Gemini free-tier RPM wall) ---
# LLM_BACKEND routes every node through one backend, no code change. Numbers below are
# documented AS the model that produced them (honest deviation from D2=Gemini), never
# relabelled as Gemini. Leave unset for the Gemini default.
#   kiro     — local gateway fronting Claude via a Kiro sub (no RPM wall; per-call token cost)
#   groq     — GPT-OSS 20b/120b (30 RPM free but 8K TPM is the real wall; bill for full runs)
#   cerebras — GPT-OSS 120b (5 RPM free; the limiter fixes the grader burst cleanly)
LLM_BACKEND=deepseek
# GROQ_API_KEY=
CEREBRAS_API_KEY=
# KIRO_API_KEY=kiro
# Shared rate limiter: caps call-start rate so the grader's ~8 concurrent calls don't burst
# past the free cap. Defaults per backend (gemini 15 / cerebras 5 / groq 30 / kiro 0=off);
# LLM_RPM overrides. Set below your paid RPM for full RAGAS-50 / MCQ runs.
# LLM_RPM=5  (disabled: deepseek is paid, no free RPM cap to throttle against)

# --- Tracing (LangSmith free tier) ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-legal-rag

# --- Vector DB (Qdrant) ---
# Local docker-compose default; override for a managed cluster.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal

# --- Retrieval knobs (defaults; see NOTES.md architecture) ---
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
RRF_K=60
OOD_DISTANCE_THRESHOLD=0.75
RETRIEVAL_LOOP_BUDGET=2

# --- HuggingFace (gated eval datasets: opennyaiorg/aibe_dataset, bharatgenai/BhashaBench-Legal) ---
HF_TOKEN=

CEREBRAS_MODEL_FLASH=gemma-4-31b
CEREBRAS_MODEL_PRO=gemma-4-31b


DEEPSEEK_API_KEY=

# Grade on the stronger pro tier (deepseek-v4-flash graded too strictly, agent bailed)
GRADER_TIER=flash
