# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- LLM (DeepSeek) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash
DEEPSEEK_MODEL_PRO=deepseek-v4-pro
# OpenAI-compatible client request timeout, in seconds.
DEEPSEEK_TIMEOUT_SECONDS=90
# DeepSeek defaults to thinking mode. This project disables it for bounded structured
# tasks and caps output to keep evaluation costs predictable.
DEEPSEEK_MAX_TOKENS_FLASH=256
DEEPSEEK_MAX_TOKENS_PRO=1024
# RAGAS answer-relevancy uses this local sentence-transformer, not another API provider.
RAGAS_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Tracing (LangSmith free tier) ---
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentic-legal-rag

# --- Vector DB (Qdrant) ---
# Optional managed Qdrant URL. Leave blank to use the embedded local index.
QDRANT_URL=
QDRANT_COLLECTION=legal

# --- Retrieval knobs (defaults; see NOTES.md architecture) ---
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
RRF_K=60
OOD_DISTANCE_THRESHOLD=0.75
RETRIEVAL_LOOP_BUDGET=2

# --- HuggingFace (gated eval datasets: opennyaiorg/aibe_dataset, bharatgenai/BhashaBench-Legal) ---
HF_TOKEN=

# Grade on the stronger pro tier (deepseek-v4-flash graded too strictly, agent bailed)
GRADER_TIER=flash
